# F5-TTS Engine — Environment Configuration
# Copy to .env and fill in your values
# Generated by install.sh — you can also edit manually

# ── Data ──────────────────────────────────────────────────────────
# Base directory for all persistent data (models, datasets, outputs)
DATA_DIR=/opt/f5tts-data

# ── Network ───────────────────────────────────────────────────────
HOST_IP=192.168.1.1
DASHBOARD_PORT=80
API_PORT=8301

# ── Voice / Model ─────────────────────────────────────────────────
VOICE_NAME=voice

# Path to the model checkpoint inside the container (/data/... maps to DATA_DIR/...)
# Base model (downloaded during install):
MODEL_PATH=/data/models/base/F5TTS_v1_Base/model_1250000.safetensors
# Fine-tuned model (after training):
# MODEL_PATH=/data/checkpoints/my_voice/model_last.pt

# Reference audio and its transcript (used for voice cloning)
REF_AUDIO=/data/refs/ref_audio.wav
REF_TEXT=

# Vocabulary file — leave empty for base model, set for custom fine-tuned model
VOCAB_FILE=
# VOCAB_FILE=/data/checkpoints/my_voice/vocab.txt

# ── Auth ──────────────────────────────────────────────────────────
ADMIN_USER=admin
# Password is stored in .htpasswd (generated by install.sh)

# ── GPU ───────────────────────────────────────────────────────────
GPU_ENABLED=false

# Compose files — auto-set by install.sh
# CPU:  COMPOSE_FILE=docker-compose.yml
# GPU:  COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml
COMPOSE_FILE=docker-compose.yml
